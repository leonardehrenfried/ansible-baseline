[Unit]
Description=Restart tileserver if it hangs
Requires=tileserver.service
After=tileserver.service

[Service]
RuntimeMaxSec=10m
Type=simple
ExecStart=/bin/sh -c "curl -o /dev/null --retry 10 -v --max-time 600 --retry-connrefused http://localhost:{{ tileserver_port }}/styles/streets/8/135/87.png || systemctl restart tileserver"

[Install]
WantedBy=multi-user.target
